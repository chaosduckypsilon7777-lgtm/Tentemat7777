# --- Baza danych ---
# SQLite (domyślnie, zero infrastruktury):
DATABASE_URL=sqlite:///./information_engine.db
# PostgreSQL (produkcja / Docker):
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/information_engine

# --- Redis (opcjonalny, nieużywany w obecnym MVP) ---
REDIS_URL=redis://localhost:6379/0

# --- HTTP ---
HTTP_TIMEOUT_SECONDS=20
FETCH_RETRY_ATTEMPTS=3
FETCH_BACKOFF_SECONDS=1.5

# --- Scheduler ---
# true  = automatyczne pobieranie źródeł w tle (zalecane)
# false = tylko ręczne fetche przez /fetch/{source}
SCHEDULER_ENABLED=true

# --- FRED (wymagane dla źródła makro) ---
# Darmowy klucz: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# --- SEC EDGAR (wymagane — SEC odrzuca anonimowe User-Agent) ---
# Zmień na prawdziwy opis i e-mail kontaktowy
SEC_USER_AGENT=information-engine/0.1 contact@example.com

# --- Anthropic (opcjonalne — generowanie podsumowań sygnałów ≥ 0.80) ---
# Klucz z https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Minimalny score do generowania podsumowania (domyślnie 0.80)
SIGNAL_SUMMARY_THRESHOLD=0.80
